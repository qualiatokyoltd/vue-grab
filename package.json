{
  "name": "vue-grab",
  "version": "0.1.0",
  "description": "Click any element in your Vue app → get component info → ask AI to change it",
  "type": "module",
  "main": "./dist/vue-grab.umd.cjs",
  "module": "./dist/vue-grab.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-grab.js",
      "require": "./dist/vue-grab.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "preview": "vite preview"
  },
  "keywords": [
    "vue",
    "vue3",
    "devtools",
    "inspector",
    "component",
    "grab",
    "click-to-component",
    "ai",
    "claude",
    "developer-experience"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue": "^3.4.0"
  }
}
